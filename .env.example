# --- Database ---------------------------------------------------------
# A pooled Postgres connection string. Vercel Postgres, Neon, and Supabase
# all work. Must be reachable from Vercel's serverless network.
DATABASE_URL="postgresql://user:password@host:5432/konnect_noc?sslmode=require"

# --- Sessions -----------------------------------------------------------
# Random string, 32+ characters, used to sign session cookies.
# Generate one with: openssl rand -base64 48
SESSION_SECRET="replace-with-a-long-random-string"

# --- Scheduled diagnostics ----------------------------------------------
# Random string. Vercel automatically sends this as
# "Authorization: Bearer <CRON_SECRET>" to your Cron Job when this
# variable is set, which /api/diagnostics/run checks before running.
# Generate one with: openssl rand -hex 32
CRON_SECRET="replace-with-a-long-random-string"

# --- First admin account (used once by `npm run db:seed`) --------------
SEED_ADMIN_NAME="Your Name"
SEED_ADMIN_EMAIL="you@konnect.co.ke"
SEED_ADMIN_PASSWORD="choose-a-strong-password"
